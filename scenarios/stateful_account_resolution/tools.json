      "properties": {
        "charge_id": {
          "type": "string"
        },
        "reason_code": {
          "type": "string"
        }
      },
      "required": [
        "charge_id",
        "reason_code"
      ]
    }
  },
  {
    "name": "escalate_billing_case",
