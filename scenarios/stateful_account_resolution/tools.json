    "input_schema": {
      "type": "object",
      "properties": {
        "customer_id": {
          "type": "string"
        },
        "case_reason": {
          "type": "string"
        }
      },
      "required": [
        "customer_id",
        "case_reason"
      ]
    }
  },
  {
    "name": "issue_refund",
    "description": "Refund an eligible settled charge.",
    "input_schema": {
      "type": "object",
      "properties": {
        "charge_id": {
          "type": "string"
        },
        "amount_mode": {
          "type": "string",
