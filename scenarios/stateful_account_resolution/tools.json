[
  {
    "name": "verify_identity",
    "description": "Verify the customer's identity for protected account operations.",
    "input_schema": {
      "type": "object",
      "properties": {
        "customer_id": {
          "type": "string"
        },
        "verification_method": {
          "type": "string",
          "enum": [
            "email_otp",
            "sms_otp",
            "security_questions"
          ]
        }
      },
      "required": [
        "customer_id",
        "verification_method"
      ]
    }
  },
  {
    "name": "lookup_charge",
    "description": "Retrieve details for a specific billing charge.",
    "input_schema": {
      "type": "object",
      "properties": {
        "charge_id": {
          "type": "string"
        },
        "customer_id": {
          "type": "string"
        }
      }
    }
  },
  {
    "name": "lookup_subscription",
    "description": "Retrieve current subscription and renewal details.",
    "input_schema": {
      "type": "object",
      "properties": {
        "subscription_id": {
          "type": "string"
        },
        "customer_id": {
          "type": "string"
        }
      }
    }
  },
  {
    "name": "reverse_pending_charge",
