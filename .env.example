# This project reads configuration from os.environ only. It does NOT auto-load
# .env files (no python-dotenv). Copying this file to .env is not enough on its
# own; export the variables in your shell, for example:
#
#   export ANTHROPIC_API_KEY=...
#   export ANTHROPIC_TASK_MODEL=claude-haiku-4-5-20251001
#   export ANTHROPIC_REPAIR_MODEL=claude-sonnet-5
#
# Or load a local .env into the current shell explicitly:
#
#   set -a; source .env; set +a

ANTHROPIC_API_KEY=

# Frozen model used for every agent rollout in every arm.
ANTHROPIC_TASK_MODEL=claude-haiku-4-5-20251001

# Used for one-shot repair generation and GEPA reflection/proposal.
ANTHROPIC_REPAIR_MODEL=claude-sonnet-5

# Optional backward-compatible shared model.
# Used only when a role-specific variable is absent.
# ANTHROPIC_MODEL=
